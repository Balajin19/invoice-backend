# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8080

# PostgreSQL Configuration (local default)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=invoice_app
DB_SSLMODE=disable

# App secret
ACCOUNT_NUMBER_KEY=your_account_number_key

# Optional Neon override (put these in .env.local instead)
# DB_HOST=ep-your-neon-host.ap-southeast-1.aws.neon.tech
# DB_PORT=5432
# DB_USERNAME=your_neon_user
# DB_PASSWORD=your_neon_password
# DB_NAME=your_neon_database
# DB_SSLMODE=require
